#* Node Environment
NODE_ENV=
#* Cors Origin
ALLOWED_ORIGINS=
#* Cookie Domain
COOKIE_DOMAIN=
#* Sever Port
PORT=
#* Database Connection String
MONGODB_URI=
#* base url
BASE_URL=
#* JWT Tokes secrets and expire
JWT_ACCESS_TOKEN_SECRET=
JWT_ACCESS_TOKEN_EXPIRY= #todo: change the value on production
JWT_REFRESH_TOKEN_SECRET=
JWT_REFRESH_TOKEN_EXPIRY=

# * Session Secret
SESSION_SECRET=

#* Gmail
GMAIL_HOST=
GMAIL_PORT=
GMAIL_USER=
GMAIL_APP_PASSWORD=

#* License Keys
LMS_URL=
LICENSE_KEY=
LICENSE_SECRET=

#* App Mode (saas | self_hosted | license )


#* Storage Configuration
# ShopXet now uses local storage with mandatory image optimization.
# Existing R2 settings are no longer used.

#* Image Optimization (Mandatory for space efficiency)
IMAGE_QUALITY=75 # 1-100 (Default: 75)
IMAGE_MAX_WIDTH=1200 # Max width in pixels (Default: 1200)
